{
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/apply",
      "has": [{ "type": "host", "value": "aimakersgeneration.com" }],
      "destination": "https://cohorts.aimakersgeneration.com/",
      "permanent": true
    },
    {
      "source": "/apply",
      "has": [{ "type": "host", "value": "www.aimakersgeneration.com" }],
      "destination": "https://cohorts.aimakersgeneration.com/",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "cohorts.aimakersgeneration.com" }],
      "destination": "/apply.html"
    },
    { "source": "/community", "destination": "/app" },
    { "source": "/community/(.*)", "destination": "/app" }
  ]
}
